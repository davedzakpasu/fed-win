{
  "name": "file-encoding-detector",
  "version": "1.0.0",
  "description": "Desktop GUI to detect character encodings of files in a folder.",
  "main": "./out/main/index.js",
  "author": "davedzakpasu",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "chardet": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.davedzakpasu.file-encoding-detector",
    "productName": "File Encoding Detector",
    "publish": {
      "provider": "github",
      "owner": "davedzakpasu",
      "repo": "fed-win"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}
