# =============================================================================
# File Encoding Detector — .gitignore
# Covers all four variants: Python, PowerShell, Node.js, Electron
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
.env
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# -----------------------------------------------------------------------------
# Node.js (nodejs/ and electron/)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Electron build outputs
# -----------------------------------------------------------------------------
electron/out/
electron/dist/

# -----------------------------------------------------------------------------
# PowerShell
# -----------------------------------------------------------------------------
# Pester output
TestResults.xml
*.TestResults.xml

# -----------------------------------------------------------------------------
# OS & editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Tool outputs (generated by the detector itself during testing)
# -----------------------------------------------------------------------------
*_encoding_*.csv
*_encoding_*.json
